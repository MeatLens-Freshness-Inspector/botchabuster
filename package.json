{
  "name": "MeatLens",
  "version": "1.0.0",
  "description": "AI-powered meat freshness inspection for wet markets",
  "author": "Annah Claire B. Dimate",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "node scripts/run-build.mjs",
    "build:all": "npm run build --workspaces",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "start": "npm run start -w backend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test -w frontend && npm run test -w backend",
    "test:unit": "npm run test:unit -w frontend && npm run test:unit -w backend",
    "test:integration": "npm run test:integration -w backend",
    "test:e2e": "npm run test:e2e -w frontend",
    "test:watch": "npm run test:e2e:ui -w frontend",
    "build:android": "npm run build:frontend && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@techstark/opencv-js": "^4.12.0-release.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  }
}
