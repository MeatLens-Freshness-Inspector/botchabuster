PORT=3001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key
APP_SESSION_SECRET=replace-with-a-long-random-secret
CSRF_TOKEN_SECRET=replace-with-a-second-long-random-secret
APP_SESSION_COOKIE_SECURE=true
# Netlify production + preview deploy example:
# ALLOWED_ORIGINS=https://your-site.netlify.app,https://*--your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:4173,http://127.0.0.1:4173
UPLOAD_DIR=./uploads
DEVELOPER_OPTIONS_PASSWORD=change-me
# Optional: defaults to DEVELOPER_OPTIONS_PASSWORD when omitted
DEVELOPER_OPTIONS_TOKEN_SECRET=change-me-too
# Optional: defaults to 21600 (6 hours)
DEVELOPER_OPTIONS_TOKEN_TTL_SECONDS=21600

# Google Mail SMTP Settings
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
